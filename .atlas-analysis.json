  "keyFeatures": [
    "Type-safe HTTP client using Swift macros",
    "Declarative service definitions with protocol-based approach",
    "Built-in support for all HTTP methods (GET, POST, PUT, PATCH, DELETE, HEAD, OPTIONS)",
    "Flexible parameter handling (path, query, header, body, form fields)",
    "Customizable service executors for different networking backends",
    "Async/await support for modern Swift concurrency",
    "Automatic JSON encoding/decoding",
    "Built on Swift 5.9+ macro system"
  ],
  "publicApiSurface": [
    "@Service macro",
